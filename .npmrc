# pnpm configuration
# Use strict peer dependencies to catch compatibility issues early
strict-peer-dependencies=false

# Enable shamefully-hoist for better compatibility with tools that expect flat node_modules
shamefully-hoist=true

# Store directory for pnpm (default is ~/.pnpm-store)
# Uncomment and customize if needed
# store-dir=~/.pnpm-store

# Auto install peers
auto-install-peers=true

# Lockfile settings
lockfile=true

# Public hoist pattern - hoist these to root node_modules for better compatibility
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*
