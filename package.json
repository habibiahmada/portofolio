{
  "name": "portofolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sitemap": "next-sitemap --config next-sitemap.config.mjs",
    "test": "vitest --run",
    "test:watch": "vitest",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "analyze:turbopack": "next experimental-analyze",
    "performance:check": "tsx scripts/performance-check.ts",
    "performance:baseline": "tsx scripts/measure-baseline.ts",
    "clean": "rm -rf .next",
    "clean:cache": "rm -rf .next/cache",
    "clean:build": "rm -rf .next && pnpm build",
    "cache:info": "tsx scripts/cache-info.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
